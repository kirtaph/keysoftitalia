# Disable PHP execution
<IfModule mod_php.c>
    php_flag engine off
</IfModule>

# Deny access to PHP files
<FilesMatch "\.php$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order deny,allow
        Deny from all
    </IfModule>
</FilesMatch>
